# TEDMaster Environment Configuration Example
# Copy this file to .env.local and fill in your actual values

# Google Gemini API Key (Get it from https://aistudio.google.com/)
GEMINI_API_KEY=your_gemini_api_key_here

# JWT secret — use a long random string (e.g. openssl rand -hex 32)
JWT_SECRET=change_me_to_a_long_random_secret

# PostgreSQL connection string
# Development (local Postgres): postgresql://user:password@localhost:5432/tedmaster
# Docker Compose: set via POSTGRES_PASSWORD below; DATABASE_URL is auto-built in docker-compose.yml
# connection_limit: max PG connections per Node.js process (keep low to avoid exhausting PG's max_connections)
# pool_timeout: seconds to wait for a free connection before throwing (default 10 is too short under load)
DATABASE_URL=postgresql://tedmaster:yourpassword@localhost:5432/tedmaster?connection_limit=10&pool_timeout=30

# Password for the postgres Docker container (used by docker-compose.yml)
POSTGRES_PASSWORD=yourpassword

# Admin panel password (access /admin)
ADMIN_PASSWORD=change_me_to_a_strong_password

# Optional: Port (default is 3000)
# PORT=3000

# DO NOT commit your actual .env.local to Git!
