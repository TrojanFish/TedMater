# Google Gemini API Key from Google AI Studio
GEMINI_API_KEY=your_gemini_api_key_here

# Secret for JWT signing
# Generate a secure random string with: openssl rand -hex 32
JWT_SECRET=your_jwt_secret_here

# Database connection string
# For Docker: postgresql://tedmaster:your_postgres_password@postgres:5432/tedmaster?connection_limit=10&pool_timeout=30
# For local DB: postgresql://user:password@localhost:5432/tedmaster?connection_limit=10&pool_timeout=30
DATABASE_URL=postgresql://tedmaster:tedmaster@postgres:5432/tedmaster?connection_limit=10&pool_timeout=30

# Password for the postgres Docker container (used by docker-compose.yml)
POSTGRES_PASSWORD=tedmaster

# Admin panel password (access /admin)
ADMIN_PASSWORD=change_this_to_a_strong_password
